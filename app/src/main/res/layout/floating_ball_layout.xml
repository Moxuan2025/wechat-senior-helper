<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#80000000"
    android:padding="8dp"
    android:elevation="8dp">

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="就绪"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:padding="8dp"
        android:background="#22000000"
        android:layout_marginBottom="8dp"
        android:maxLines="3"
        android:ellipsize="end"
        android:visibility="gone" />

    <EditText
        android:id="@+id/et_search_contact"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:hint="输入联系人名"
        android:textSize="12sp"
        android:minWidth="120dp"
        android:background="#FFFFFF"
        android:paddingLeft="4dp"
        android:textColor="#000000"
        android:textColorHint="#888888"
        android:layout_marginBottom="4dp" />

    <Button
        android:id="@+id/btn_search_contact"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="搜索联系人"
        android:textSize="12sp"
        android:minWidth="100dp"
        android:layout_marginBottom="4dp" />

    <Button
        android:id="@+id/btn_open_wechat"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="打开微信"
        android:textSize="12sp"
        android:minWidth="100dp"
        android:layout_marginBottom="4dp" />

    <Button
        android:id="@+id/btn_execute_tx"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="返回事务"
        android:textSize="12sp"
        android:minWidth="100dp"
        android:layout_marginBottom="4dp" />

    <Button
        android:id="@+id/btn_send_voice"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="发送语音"
        android:textSize="12sp"
        android:minWidth="100dp"
        android:layout_marginBottom="4dp" />

    <Button
        android:id="@+id/btn_video_call"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="语音通话"
        android:textSize="12sp"
        android:minWidth="100dp"
        android:layout_marginBottom="4dp" />

    <!-- 意图输入 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp">

        <EditText
            android:id="@+id/et_intent_text"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="说你想做的..."
            android:textSize="14sp"
            android:background="#FFFFFF"
            android:paddingHorizontal="8dp"
            android:textColor="#000000"
            android:textColorHint="#888888"
            android:minWidth="100dp" />

        <Button
            android:id="@+id/btn_send_intent"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="发送"
            android:textSize="14sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_confirm"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="确认执行"
        android:textSize="12sp"
        android:minWidth="100dp"
        android:visibility="gone"
        android:layout_marginBottom="4dp" />

    <Button
        android:id="@+id/btn_stop"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="停止服务"
        android:textSize="12sp"
        android:minWidth="100dp"
        android:backgroundTint="#FF5252" />

</LinearLayout>
